{
  "version": 2,
  "builds": [
    {
      "src": "main.py",
      "use": "@vercel/python"
    },
    {
      "src": "static/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/(style.css|script.js|logo.png|.*\\.png|.*\\.webp|.*\\.jpg|.*\\.jpeg)",
      "dest": "/static/$1"
    },
    {
      "src": "/status/(.*)",
      "dest": "main.py"
    },
    {
      "src": "/upload",
      "dest": "main.py"
    },
    {
      "src": "/upload-pvid",
      "dest": "main.py"
    },
    {
      "src": "/download/(.*)",
      "dest": "main.py"
    },
    {
      "src": "/(.*)",
      "dest": "main.py"
    }
  ]
}
